# 数据库配置
DATABASE_URL=sqlite:///./jkxt.db
# SECRET_KEY for JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# 人脸识别配置
FACE_SIMILARITY_THRESHOLD=0.6

# 通知配置
WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# 服务器配置
HOST=0.0.0.0
PORT=8000
